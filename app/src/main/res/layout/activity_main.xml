<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 標題 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="自動連點器"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="在任何 App 上方自動點擊"
            android:textSize="14sp"
            android:textColor="#757575"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- 權限區塊 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="① 權限設定"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="12dp" />

        <!-- 懸浮視窗權限 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="懸浮視窗權限"
                    android:textSize="15sp"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/tv_overlay_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✗ 未開啟"
                    android:textSize="13sp"
                    android:textColor="#F44336" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_overlay_perm"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="前往設定"
                android:textSize="13sp"
                android:backgroundTint="#2196F3" />
        </LinearLayout>

        <!-- 無障礙服務權限 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="無障礙服務"
                    android:textSize="15sp"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/tv_access_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✗ 未開啟"
                    android:textSize="13sp"
                    android:textColor="#F44336" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_access_perm"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="前往設定"
                android:textSize="13sp"
                android:backgroundTint="#2196F3" />
        </LinearLayout>

        <!-- 速度設定 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="② 點擊速度"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="點擊間隔"
                    android:textSize="15sp"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/tv_interval"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500 ms"
                    android:textSize="15sp"
                    android:textColor="#2196F3"
                    android:textStyle="bold" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_interval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="10" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="快 50ms"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="慢 5000ms"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="提示：啟動後拖曳十字準星到想要點擊的位置"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- 啟動按鈕 -->
        <Button
            android:id="@+id/btn_toggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="啟動連點器"
            android:textSize="18sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- 使用說明 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="使用說明"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:text="1. 開啟上方兩個權限\n2. 調整點擊速度\n3. 按下「啟動連點器」\n4. 切換到目標 App\n5. 拖曳十字準星 ⊕ 到要點擊的位置\n6. 點擊懸浮氣泡展開面板\n7. 按 ▶ 開始連點、按 ⏸ 暫停\n8. 按 ⏹ 結束並關閉"
            android:textSize="14sp"
            android:textColor="#424242"
            android:lineSpacingExtra="6dp" />

    </LinearLayout>
</ScrollView>
